
<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <title><%= title %></title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>


  <h1><%= title %></h1>
  <% if (data_yes) { %>
  <form action="/sorted" method="get">
      <select name="orderStatus" id="orderStatus">
        <option disabled selected>Выберите статус</option>
        <% for (const key in statuses) { %>
          <% const status = statuses[key]; %>
          <option value="<%= key %>" style="color: <%= status.color %>;">
            <%= status.label %>
          </option>
        <% } %>
      <option value="" style="color: #333;">Все заказы</option>
      </select>
  </form>
<script>
     
      const orderStatus = document.getElementById('orderStatus');
      
      function updateTabel(){
          const status = orderStatus.value;
          console.log(status);

          fetch('/filter', {
              method : 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ 'status' : status})          
          })
              .then(response => response.json())
              .then(data => {update_cell(table_order, data)})
              .catch(error => console.error('Error updating table:', error));




      }

      function update_cell(table, data){

        const table_order = document.getElementById('table_order');
        const tbody = table ? table.querySelector('tbody') : null;

        const rows = data[`rows`];
        const size = data[`length`];
        const statuses = data[`statuses`];
        tbody.innerHTML = '';
        let html = '';

        for (let i = 0; i < size; i++) { 

        const statusInfo = statuses[rows[i].STATUS];
        const color = statusInfo?.color ?? '#eee';
        const label = statusInfo?.label ?? rows[i].STATUS; 

        html += `
            <tr>
              <td>${rows[i].ID}</td>
              <td>${rows[i].NUMBER}</td>
              <td style="background-color: ${color}; color: white;">
                ${label}
              </td>
              <td>${rows[i].formattedDate}</td> 
              <td style="text-align: center; vertical-align: middle;">  
                <form action="/view/${rows[i].ID}" method="get">
                  <button type="submit" style="padding: 5px 10px;">Открыть</button>
                </form>
              </td>
              <td style="text-align: center; vertical-align: middle;">
                <form action="/delete/${rows[i].ID}" method="get">
                  <button type="submit" style="padding: 5px 10px; background-color: #ffcccc;">Удалить</button>
                </form>
              </td>                                                         
            </tr>
          `;

        }
        tbody.innerHTML = html;




      }


    orderStatus.addEventListener('change', updateTabel);




</script>

<table id="table_order">
  <thead>
    <tr>
      <th>ID</th>
      <th>Заказ-наряд</th>
      <th>Статус</th> 
      <th>Дата заявки</th>                
      <th>Действия</th> 
    </tr>
  </thead>
  <tbody>
    <% if (rows && rows.length > 0) { %>
      <% rows.forEach(row => { %> 
        <tr>
          <td><%= row.ID %></td>
          <td><%= row.NUMBER %></td>

          <td style="background-color: <%= statuses[row.STATUS] ? statuses[row.STATUS].color : '#eee' %>; color: white;">
            <%= statuses[row.STATUS] ? statuses[row.STATUS].label : row.STATUS %>
          </td> 
          <td><%= row.formattedDate %></td>           
          <td style="text-align: center; vertical-align: middle;">  
            <form action="/view/<%= row.ID %>" method="get">
              <button type="submit" style="padding: 5px 10px;">Открыть</button>
            </form>
          </td>
          <td style="text-align: center; vertical-align: middle;">
            <form action="/delete/<%= row.ID %>" method="get">
              <button type="submit" style="padding: 5px 10px; background-color: #ffcccc;">Удалить</button>
            </form>
          </td>                                
        </tr>
      <% }); %>
    <% } else { %>
      <tr><td colspan="6" style="text-align:center;">Нет данных</td></tr>
    <% } %>
  </tbody>
</table>
  <% } else { %>
  <h2>Записей не найдено...</h2>
  <% } %>
  <form action="/add" method="get">
    <button class = "in_cell" type="submit">Добавить</button>
  </form>
</body>
</html>