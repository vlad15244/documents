<!DOCTYPE html>
<html lang="ru">
  <head>
  <meta charset="UTF-8" />
  <title><%= title %></title>
  <style>
    body { font-family: Arial, sans-serif; padding: 20px; background: #f5f5f5; }
    h1 { color: #333; }
    h2 { color: #21da7e; }    
    table { width: 100%; border-collapse: collapse; background: white; }
    th, td { border: 1px solid #ddd; padding: 8px 12px; text-align: left; }
    th { background: #eee; }
    .status-badge {
      padding: 4px 8px;
      border-radius: 4px;
      color: white;
      font-size: 0.85rem;
      font-weight: bold;
    }
    button {
        padding: 8px 30px;
        border-radius: 6px;
        margin-top: 8px;
        border: 2px solid #b7c612;
        cursor: pointer;
    }
    button.in_cell {
        padding: 8px 30px;
        border-radius: 6px;
        border: 2px solid #b7c612;
        cursor: pointer;
    }
    input{
        padding: 8px 30px;
        border-radius: 6px;       
        border: 2px solid #b7c612;
        text-align: center;
        font-family: 'Garamond', Times, serif;
        font-size: small;
    }
    select{
        padding: 8px 30px;
        border-radius: 6px;       
        border: 2px solid #b7c612;
        text-align: center;
        font-family: 'Times New Roman', Times, serif;
        font-size: small;
    }    
  </style>

</head>
<body>
  <h1>Данные для добавления</h1>
    <form action="/add" method="post">
      <input type="text" name="name" placeholder="Введите ваш заказ-наряд">    
      <label for="status-select">Статус:</label>
      <select name="orderStatus" id="orderStatus">
        <option value="" disabled selected>Выберите статус</option>
        <% for (const key in statuses) { %>
          <% const status = statuses[key]; %>
          <option value="<%= key %>" style="color: <%= status.color %>;">
            <%= status.label %>
          </option>
        <% } %>
      </select>
      <label for="order_date">Дата заявки:</label>
      <input type="date" id="order_date" name="order_date">
      <button type="submit">Добавить</button>

  </form>
</body>

</html>