<!DOCTYPE html>
<html lang="ru">
<body>
  <h1>Данные для добавления</h1>
    <form action="/add" method="post">
      <input type="text" name="name" placeholder="Введите ваш номер">    
      <label for="car-select">Выберите марку автомобиля:</label>
      <select id="car-select" name="car">
        <option value="">--Выберите вариант--</option>
        <option value="bmw">BMW</option>
        <option value="audi" selected>Audi</option>
        <option value="mers">Mercedes</option>
      </select>  
      <button type="submit">Добавить</button>
  </form>
</body>

</html>